{
    "name": "ingoschock/php-api-slim",
    "description": "REST API built with Slim Framework",
    "type": "project",
    "require": {
        "php": "^8.3",
        "php-di/php-di": "^7.1",
        "php-di/slim-bridge": "^3.4",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
