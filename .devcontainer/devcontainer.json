{
  "name": "PHP 8.5 API with Slim and PHP-DI",
  "dockerFile": "Dockerfile",
  "appPort": 80,
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug"
      ],
      "settings": {
        "php.validate.executablePath": "/usr/local/bin/php",
        "php.debug.executablePath": "/usr/local/bin/php"
      }
    }
  },
  "forwardPorts": [
    80
  ],
  "postCreateCommand": "composer install && a2enmod rewrite && service apache2 restart",
  "remoteUser": "vscode"
}